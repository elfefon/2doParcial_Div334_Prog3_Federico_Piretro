<%- include("partials/head.ejs") %>
<%- include("partials/nav.ejs") %>

    <main>

        <section class="secccion-productos">
            <h2> <%=  about %></h2>

            <div class="admin-filters">
                <div class="filter-row">
                    <button class="admin-filter-btn<%= filtros.categoria === 'todas' ? ' active' : '' %>" data-filter="categoria" data-value="todas">Todas</button>
                    <button class="admin-filter-btn<%= filtros.categoria === 'local' ? ' active' : '' %>" data-filter="categoria" data-value="local">Local</button>
                    <button class="admin-filter-btn<%= filtros.categoria === 'visitante' ? ' active' : '' %>" data-filter="categoria" data-value="visitante">Visitante</button>
                </div>
                <div class="filter-row">
                    <button class="admin-filter-btn<%= filtros.estado === 'todos' ? ' active' : '' %>" data-filter="estado" data-value="todos">Todos</button>
                    <button class="admin-filter-btn<%= filtros.estado === 'activos' ? ' active' : '' %>" data-filter="estado" data-value="activos">Activos</button>
                    <button class="admin-filter-btn<%= filtros.estado === 'inactivos' ? ' active' : '' %>" data-filter="estado" data-value="inactivos">Inactivos</button>
                </div>
            </div>

            <div id="contenedor-productos">

                <% 
                productsArray.forEach(producto => { 
                const inactivo = (producto.active == 0);
                %>

                    <div class="card-producto<%= inactivo ? ' disabled' : '' %>"
                         data-categoria="<%= producto.category %>"
                         data-active="<%= producto.active %>">
                        <img src="<%= producto.image %>" alt="<%= producto.name %>" onerror="this.onerror=null;this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22300%22 height=%22200%22><rect fill=%22%23f0f0f0%22 width=%22300%22 height=%22200%22/><text fill=%22%23999%22 font-family=%22Arial%22 font-size=%2214%22 text-anchor=%22middle%22 x=%22150%22 y=%22105%22>'+encodeURIComponent(this.alt)+'</text></svg>';">
                        <h4><%= producto.name %></h4>
                        <p>Id: <%= producto.id %> | Pais: <%= producto.country %></p>
                        <p>$<%= producto.price %></p>
                        <% if (inactivo) { %>
                            <p class="badge-inactivo">INACTIVO</p>
                        <% } %>
                    </div>

                <% }) %>

            </div>

            <% if (pagination && pagination.totalPages > 1) { %>
            <div class="admin-pagination">
                <button class="admin-page-btn" <%= pagination.page <= 1 ? 'disabled' : '' %>
                    onclick="irAPagina(<%= pagination.page - 1 %>)">Anterior</button>

                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                    <button class="admin-page-btn<%= i === pagination.page ? ' active' : '' %>"
                        onclick="irAPagina(<%= i %>)"><%= i %></button>
                <% } %>

                <button class="admin-page-btn" <%= pagination.page >= pagination.totalPages ? 'disabled' : '' %>
                    onclick="irAPagina(<%= pagination.page + 1 %>)">Siguiente</button>
            </div>
            <% } %>
        </section>
    </main>

<script>
const filtrosActuales = {
    categoria: "<%= filtros.categoria %>",
    estado: "<%= filtros.estado %>"
};

function construirURL(page) {
    const params = new URLSearchParams();
    params.set("page", page);
    if (filtrosActuales.categoria !== "todas") params.set("categoria", filtrosActuales.categoria);
    if (filtrosActuales.estado !== "todos") params.set("estado", filtrosActuales.estado);
    return params.toString();
}

function irAPagina(page) {
    window.location.search = construirURL(page);
}

document.addEventListener("DOMContentLoaded", () => {
    const filtros = document.querySelectorAll(".admin-filter-btn");

    filtros.forEach(btn => {
        btn.addEventListener("click", () => {
            const grupo = btn.dataset.filter;
            const valor = btn.dataset.value;

            filtrosActuales[grupo] = valor;

            window.location.search = construirURL(1);
        });
    });
});
</script>

<%- include("partials/footer.ejs") %>
