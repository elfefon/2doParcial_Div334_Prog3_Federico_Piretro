<%- include("partials/head.ejs") %>
<%- include("partials/nav.ejs") %>

<main>

    <section class="form-productos">
        <h2> <%= about %> </h2>
        
        <form id="postProduct-form" class="form-alta" enctype="multipart/form-data">
            <label for="nameProd">Nombre</label>
            <input type="text" name="name" id="nameProd" required>

            <fieldset class="imagen-fieldset">
                <legend>Imagen del producto (opcional)</legend>

                <div class="imagen-opciones">
                    <label class="radio-label">
                        <input type="radio" name="imagenTipo" value="url" checked> URL de imagen
                    </label>
                    <label class="radio-label">
                        <input type="radio" name="imagenTipo" value="archivo"> Subir archivo
                    </label>
                </div>

                <div id="input-url" class="imagen-input">
                    <label for="imageUrl">URL de la imagen</label>
                    <input type="url" name="imageUrl" id="imageUrl" placeholder="https://ejemplo.com/imagen.jpg">
                </div>

                <div id="input-archivo" class="imagen-input" style="display:none;">
                    <label for="imageFile">Seleccionar archivo</label>
                    <input type="file" name="imageFile" id="imageFile" accept="image/*">
                </div>
            </fieldset>

            <label for="categoryProd">Categoria</label>
            <select name="category" id="categoryProd" required>
                <option value="local">Local</option>
                <option value="visitante">Visitante</option>
            </select>

            <label for="countryProd">Pais</label>
            <input type="text" name="country" id="countryProd" required>

            <label for="priceProd">Precio</label>
            <input type="number" name="price" id="priceProd" required>
            
            <div>
                <input type="submit" value="Crear producto">
            </div>
        </form>

    </section>

    <section class="secccion-productos">
        <div id="contenedor-productos">

        </div>
    </section>
</main>

<script src="/js/post.js"></script>
<%- include("partials/footer.ejs") %>