<header>
    <div class="logo">
        <a href="/dashboard/index" class="logo-container">
            <img src="/assets/img/logoPaginaPelota.jpg" alt="logo pelota">
        </a>
    </div>

    <ul class="enlaces">
        <li class="enlace">
            <a href="/dashboard/index">
                <span>VER</span>
            </a>
        </li>

        <li class="enlace">
            <a href="/dashboard/get">
                <span>CONSULTAR</span>
            </a>
        </li>

        <li class="enlace">
            <a href="/dashboard/post">
                <span>CREAR</span>
            </a>
        </li>

        <li class="enlace">
            <a href="/dashboard/put">
                <span>MODIFICAR</span>
            </a>
        </li>

        <li class="enlace">
            <a href="/dashboard/delete">
                <span>ELIMINAR</span>
            </a>
        </li>
    </ul>

    <div class="nav-actions">
        <a href="/api/purchases/excel" class="admin-excel-icon" download title="Descargar Excel">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1a7a3a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v13"/>
                <path d="m8 13 4 4 4-4"/>
                <path d="M4 19h16"/>
            </svg>
        </a>
        <button class="admin-theme-toggle" onclick="toggleAdminTheme()" title="Cambiar tema">☾</button>

        <span class="nav-user-name"><%= user.nombre %></span>
        <a href="/logout" class="admin-excel-icon" title="Cerrar sesión">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
        </a>
    </div>
</header>